@model NdlovuBetting.Models.ViewModels.UsersListViewModel
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">User Management</h3>
    <a asp-controller="Users" asp-action="CreateAdmin" class="btn btn-nb">+ New Admin</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- STATS -->
<div class="row g-2 mb-3">
    <div class="col-6 col-md-3"><div class="nb-stat"><div class="n">@Model.TotalUsers</div><div class="l">Total Users</div></div></div>
    <div class="col-6 col-md-3"><div class="nb-stat"><div class="n">@Model.TotalClients</div><div class="l">Clients</div></div></div>
    <div class="col-6 col-md-3"><div class="nb-stat"><div class="n">@Model.TotalAccounts</div><div class="l">Accounts</div></div></div>
    <div class="col-6 col-md-3"><div class="nb-stat"><div class="n">@Model.GrandTotalBalance.ToString("C0")</div><div class="l">Total Balance</div></div></div>
</div>

<!-- SEARCH -->
<form asp-action="Index" method="get" class="nb-panel p-3 mb-3">
    <div class="row g-2">
        <div class="col-md-9">
            <input name="search" value="@Model.Search" class="form-control"
                   placeholder="Search by ID number, surname, name, email or account number..." />
        </div>
        <div class="col-md-3 d-grid">
            <button type="submit" class="btn btn-nb">Search</button>
        </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.Search))
    {
        <a asp-action="Index" class="small d-inline-block mt-2" style="color:var(--nb-muted);">Clear search</a>
    }
</form>

<!-- TABLE -->
<div class="nb-panel p-0">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Role</th>
                    <th class="text-center">Accounts</th>
                    <th class="text-end">Balance</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Users.Any())
                {
                    <tr><td colspan="8" class="text-center text-secondary py-4">No users found.</td></tr>
                }
                else
                {
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>@u.FullName</td>
                            <td>@u.Email</td>
                            <td>@(string.IsNullOrEmpty(u.PhoneNumber) ? "—" : u.PhoneNumber)</td>
                            <td>
                                @if (u.Role == "Admin")
                                {
                                    <span class="pill pill-admin">admin</span>
                                }
                                else
                                {
                                    <span class="pill pill-client">client</span>
                                }
                            </td>
                            <td class="text-center">@u.AccountCount</td>
                            <td class="text-end">@(u.Role == "Admin" ? "—" : u.TotalBalance.ToString("C"))</td>
                            <td>@u.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@u.Id" class="btn btn-nb btn-xs">Details</a>
                                <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-outline-light btn-xs">Edit</a>
                                <a asp-action="Delete" asp-route-id="@u.Id" class="btn btn-outline-danger btn-xs">Delete</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- PAGINATION -->
@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm mb-0">
            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page - 1)">Prev</a>
            </li>
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-search="@Model.Search" asp-route-page="@(Model.Page + 1)">Next</a>
            </li>
        </ul>
    </nav>
}
<p class="text-secondary mt-2" style="font-size:12px;">
    Showing @Model.Users.Count of @Model.TotalCount users · @Model.PageSize per page
</p>