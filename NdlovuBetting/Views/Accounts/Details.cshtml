@model NdlovuBetting.Models.ViewModels.AccountDetailsViewModel
@{
    ViewData["Title"] = "Account Details";
}

<a asp-controller="Users" asp-action="Details" asp-route-id="@Model.OwnerId"
   style="color:var(--nb-green);text-decoration:none;font-size:13px;">&larr; Back to user</a>

<div class="d-flex justify-content-between align-items-center mb-3 mt-2">
    <h3 class="mb-0">Account @Model.AccountNumber</h3>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-light btn-sm">Edit</a>
        @if (Model.IsClosed)
        {
            <a asp-action="Reopen" asp-route-id="@Model.Id" class="btn btn-outline-success btn-sm">Reopen Account</a>
        }
        else
        {
            <a asp-action="Close" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Close Account</a>
        }
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<!-- SUMMARY -->
<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="nb-stat">
            <div class="l">Balance</div>
            <div class="n" style="color:var(--nb-green);">@Model.Balance.ToString("C")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="nb-stat">
            <div class="l">Status</div>
            <div class="n">
                @if (Model.IsClosed)
                {
                    <span class="pill" style="background:rgba(139,148,163,.18);color:#aeb6c2;">Closed</span>
                }
                else
                {
                    <span class="pill pill-client">Open</span>
                }
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="nb-stat">
            <div class="l">Owner</div>
            <div class="n" style="font-size:16px;">@Model.OwnerName</div>
        </div>
    </div>
</div>

<!-- TRANSACTIONS -->
<div class="nb-panel p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="nb-section">Transactions</div>
        @if (!Model.IsClosed)
        {
            <a asp-action="AddTransaction" asp-route-accountId="@Model.Id" class="btn btn-nb btn-xs">+ Add Transaction</a>
        }
    </div>

    @if (!Model.Transactions.Any())
    {
        <p class="text-secondary mb-0">No transactions yet.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0" style="font-size:14px;">
                <thead>
                    <tr><th>Date</th><th>Type</th><th>Description</th><th class="text-end">Amount</th><th>Captured</th><th class="text-end"></th></tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.Transactions)
                    {
                        <tr>
                            <td>@t.TransactionDate.ToString("yyyy-MM-dd")</td>
                            <td>
                                @if (t.Type == "Credit")
                                {
                                    <span class="pill pill-client">Credit</span>
                                }
                                else
                                {
                                    <span class="pill pill-admin">Debit</span>
                                }
                            </td>
                            <td>@(string.IsNullOrEmpty(t.Description) ? "—" : t.Description)</td>
                            <td class="text-end">@t.SignedAmount.ToString("C")</td>
                            <td style="color:var(--nb-muted);">@t.CapturedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-end">
                                <a asp-action="EditTransaction" asp-route-id="@t.Id" class="btn btn-outline-light btn-xs">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
