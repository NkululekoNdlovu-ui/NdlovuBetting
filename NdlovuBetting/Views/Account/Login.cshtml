@model NdlovuBetting.Models.Dtos.LoginDto
@{
    ViewData["Title"] = "Log In";
}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="nb-panel p-4">
            <h1 class="mb-1">Log in</h1>
            <p class="text-secondary mb-3" style="font-size:.9rem;">Welcome back to NdlovuBetting.</p>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" placeholder="you@email.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="form-check mb-3">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <button type="submit" class="btn btn-nb w-100 py-2">Log In</button>
            </form>

            <p class="mt-3 text-center text-secondary" style="font-size:.9rem;">
                No account yet? <a asp-action="Register">Sign up</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}